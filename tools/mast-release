#!/usr/bin/env python3
"""mast-release — coordinate annotated git tags across every MAST_* repo.

Tags are the single source of truth for release identity across the MAST
ecosystem. This CLI applies the same annotated tag at HEAD of every MAST_*
repo in the workspace, then runs the build report and offers an explicit
push prompt only if the report comes back coherent.

Usage:
    mast-release tag <name> <message>            # tag locally
    mast-release tag <name> <message> --yes      # skip pre-tag confirmation
    mast-release push <name>                     # push existing tag to origin
    mast-release list [pattern]                  # show tags across all repos
"""

# ── venv auto-loader ──────────────────────────────────────────────────────────
import os
import sys
from pathlib import Path

_venv_dir = Path(__file__).resolve().parent.parent / ".venv"
_venv_python = _venv_dir / "bin" / "python"
if _venv_python.exists() and Path(sys.prefix) != _venv_dir:
    os.execv(str(_venv_python), [str(_venv_python)] + sys.argv)

# ── imports ───────────────────────────────────────────────────────────────────
import argparse  # noqa: E402
import subprocess  # noqa: E402
from dataclasses import dataclass  # noqa: E402

# `mast-release` lives at <workspace>/MAST_control/tools/mast-release
WORKSPACE_ROOT = Path(__file__).resolve().parents[2]

# Reuse the build-report collector & renderer from MAST_common (vendored as
# `common/` submodule inside MAST_control).
sys.path.insert(0, str(WORKSPACE_ROOT / "MAST_control"))
from common.build_report import (  # noqa: E402
    MAST_REPO_PREFIX,
    collect_build_report,
    format_text,
)

EXIT_OK = 0
EXIT_PREFLIGHT = 1
EXIT_PARTIAL_TAG = 2
EXIT_PUSH_GATE = 3
EXIT_PARTIAL_PUSH = 4

PUSH_REMOTE = "origin"
# Order tried when determining each repo's canonical mainline. The first ref
# that exists and resolves is used. upstream is preferred because we treat it
# as the canonical source of truth across the ecosystem (see DECISIONS.md);
# origin is the fallback for repos that only have a single remote.
CANONICAL_REFS = (
    "refs/remotes/upstream/master",
    "refs/remotes/upstream/main",
    "refs/remotes/origin/main",
    "refs/remotes/origin/master",
)


@dataclass
class RepoState:
    name: str
    path: Path
    target_sha: str            # commit this repo will be tagged at
    target_descriptor: str     # human-readable description of where target came from
    tag_at_target: bool        # True if requested tag already points at target (noop)
    error: str | None = None


def _run(args: list[str], cwd: Path) -> subprocess.CompletedProcess[str]:
    return subprocess.run(args, cwd=cwd, capture_output=True, text=True, check=False)


def _discover_repos() -> list[Path]:
    repos: list[Path] = []
    for child in sorted(WORKSPACE_ROOT.iterdir()):
        if not child.is_dir():
            continue
        if not child.name.startswith(MAST_REPO_PREFIX):
            continue
        if not (child / ".git").exists():
            continue
        repos.append(child)
    return repos


def _canonical_ref(repo: Path) -> str | None:
    """Pick the first canonical mainline ref present in `repo`, or None."""
    for ref in CANONICAL_REFS:
        if _run(["git", "rev-parse", "--verify", "--quiet", ref], repo).returncode == 0:
            return ref
    return None


def _resolve_tag_target(
    repo: Path, prefer_ref: str | None
) -> tuple[str | None, str, str | None]:
    """Resolve the commit this repo should be tagged at.

    Returns (commit_sha, descriptor, comparison_ref). `comparison_ref` is the
    full ref used for the freshness check — for HEAD or a working branch we
    compare against canonical mainline; for the canonical-fallback case
    freshness is trivially satisfied so it returns None.

    With `prefer_ref` set: use that local branch's tip if it exists, otherwise
    fall back to the canonical mainline. Without it: tag HEAD (legacy
    behaviour, used when no --from flag is passed).
    """
    if prefer_ref is None:
        # Legacy: tag current HEAD on whatever branch is checked out.
        head_sha = _run(["git", "rev-parse", "HEAD"], repo).stdout.strip()
        branch = _run(["git", "rev-parse", "--abbrev-ref", "HEAD"], repo).stdout.strip()
        canonical = _canonical_ref(repo)
        descriptor = f"HEAD ({branch})"
        return head_sha or None, descriptor, canonical

    local_ref = f"refs/heads/{prefer_ref}"
    if _run(["git", "rev-parse", "--verify", "--quiet", local_ref], repo).returncode == 0:
        sha = _run(["git", "rev-parse", local_ref], repo).stdout.strip()
        canonical = _canonical_ref(repo)
        return sha, f"branch {prefer_ref}", canonical

    canonical = _canonical_ref(repo)
    if canonical is None:
        return None, "<no target>", None
    sha = _run(["git", "rev-parse", canonical], repo).stdout.strip()
    short = canonical.replace("refs/remotes/", "")
    # Canonical-fallback target IS canonical, so freshness check is moot.
    return sha or None, f"{short} (fallback — {prefer_ref!r} not in this repo)", None


def _fetch_all(repo: Path) -> None:
    """Best-effort fetch from every remote so freshness checks see latest tips.

    Failures (e.g. MAST_unit's known-broken `origin`) are intentionally
    ignored: as long as *some* canonical ref resolves, the freshness check
    has something to compare against. Real freshness gaps will still surface
    against whichever remote did fetch successfully.
    """
    _run(["git", "fetch", "--all", "--quiet"], repo)


def _preflight(
    repos: list[Path],
    tag_name: str,
    *,
    check_freshness: bool,
    prefer_ref: str | None,
) -> tuple[list[RepoState], list[str]]:
    """Resolve each repo's tag target and validate it.

    `prefer_ref` (the `--from` value, may be None) selects which commit to tag
    in each repo: that named local branch if it exists, otherwise the repo's
    canonical mainline tip. Without it the tagger uses HEAD (legacy behaviour).
    """
    states: list[RepoState] = []
    failures: list[str] = []
    for repo in repos:
        if check_freshness:
            _fetch_all(repo)

        # Dirty-tree check: still informative when tagging HEAD; less critical
        # when tagging a non-HEAD ref but kept because uncommitted state often
        # signals confusion. Cheap to keep, easy to clear.
        porcelain = _run(["git", "status", "--porcelain"], repo)
        if porcelain.stdout.strip():
            failures.append(f"{repo.name}: working tree dirty")
            continue

        # Detached HEAD only matters when we're tagging HEAD itself.
        if prefer_ref is None:
            branch = _run(["git", "rev-parse", "--abbrev-ref", "HEAD"], repo).stdout.strip()
            if branch == "HEAD":
                failures.append(f"{repo.name}: detached HEAD (and no --from given)")
                continue

        target_sha, descriptor, comparison_ref = _resolve_tag_target(repo, prefer_ref)
        if not target_sha:
            failures.append(
                f"{repo.name}: cannot resolve tag target ({descriptor}) — "
                f"neither {prefer_ref!r} nor a canonical mainline ref was found"
            )
            continue

        if check_freshness and comparison_ref is not None:
            # Target is stale if canonical mainline isn't an ancestor of it.
            ancestor = _run(
                ["git", "merge-base", "--is-ancestor", comparison_ref, target_sha], repo
            )
            if ancestor.returncode != 0:
                canonical_short = comparison_ref.replace("refs/remotes/", "")
                behind = _run(
                    ["git", "rev-list", "--count", f"{target_sha}..{comparison_ref}"], repo
                ).stdout.strip() or "?"
                failures.append(
                    f"{repo.name}: {descriptor} is stale — {behind} commit(s) behind "
                    f"{canonical_short}. Merge it in first, or pass --allow-stale to override."
                )
                continue

        tag_at_target = False
        tag_check = _run(["git", "rev-parse", "--verify", f"refs/tags/{tag_name}"], repo)
        if tag_check.returncode == 0:
            tagged_commit = _run(["git", "rev-list", "-n", "1", f"refs/tags/{tag_name}"], repo)
            if tagged_commit.returncode == 0 and tagged_commit.stdout.strip() == target_sha:
                tag_at_target = True
            else:
                failures.append(
                    f"{repo.name}: tag '{tag_name}' already exists at a different SHA "
                    f"({(tagged_commit.stdout.strip() or '?')[:9]} vs target {target_sha[:9]})"
                )
                continue

        states.append(
            RepoState(
                name=repo.name,
                path=repo,
                target_sha=target_sha,
                target_descriptor=descriptor,
                tag_at_target=tag_at_target,
            )
        )
    return states, failures


def _print_plan(states: list[RepoState], tag_name: str) -> None:
    print(f"Tag plan: {tag_name}")
    print(f"{'Repo':<26} {'Target':<48} {'SHA':<10} Action")
    print("-" * 96)
    for s in states:
        action = "already-tagged-noop" if s.tag_at_target else "tag"
        print(f"{s.name:<26} {s.target_descriptor:<48} {s.target_sha[:9]:<10} {action}")


def _confirm_by_typing(tag_name: str, prompt: str) -> bool:
    print(prompt)
    try:
        entered = input("> ").strip()
    except EOFError:
        return False
    if entered != tag_name:
        print(f"Got {entered!r}, expected {tag_name!r}. Aborting.")
        return False
    return True


def _apply_tags(states: list[RepoState], tag_name: str, message: str) -> list[str]:
    failures: list[str] = []
    for s in states:
        if s.tag_at_target:
            print(f"  {s.name}: already at {tag_name}, skipping")
            continue
        # Explicit-commit form so we tag the resolved target even when it isn't HEAD.
        res = _run(["git", "tag", "-a", tag_name, "-m", message, s.target_sha], s.path)
        if res.returncode != 0:
            failures.append(f"{s.name}: {res.stderr.strip() or 'tag failed'}")
            print(f"  {s.name}: FAILED — {res.stderr.strip()}")
        else:
            print(f"  {s.name}: tagged {s.target_sha[:9]} ({s.target_descriptor})")
    return failures


def _evaluate_push_gate(
    workspace_root: Path,
    tag_name: str,
    repos: list[Path],
    expected_by_name: dict[str, str] | None = None,
) -> list[str]:
    """Return list of human-readable reasons why the push gate did not pass.

    `expected_by_name` (optional) maps repo name to the commit SHA we expect
    the tag to resolve to (the per-repo tag target from the resolver). When
    omitted we fall back to checking against the report's HEAD SHA — that's
    correct when the tag was applied to HEAD (the no-`--from` case).

    Empty return list = gate passes.
    """
    reasons: list[str] = []
    report = collect_build_report(workspace_root)
    print()
    print(format_text(report))
    print()

    if len(report.common_sha_consistency) > 1:
        reasons.append(
            f"MAST_common SHA drift: {len(report.common_sha_consistency)} distinct SHAs referenced"
        )
    for r in report.repos:
        if r.error:
            reasons.append(f"{r.name}: report error: {r.error}")

    fallback_by_name: dict[str, str | None] = {r.name: r.head_sha for r in report.repos}
    for repo in repos:
        expected = None
        if expected_by_name is not None:
            expected = expected_by_name.get(repo.name)
        if expected is None:
            expected = fallback_by_name.get(repo.name)
        if not expected:
            reasons.append(f"{repo.name}: no expected SHA for tag verification")
            continue
        tagged = _run(["git", "rev-parse", "--verify", f"refs/tags/{tag_name}^{{commit}}"], repo)
        if tagged.returncode != 0:
            reasons.append(f"{repo.name}: tag {tag_name} not found locally after tagging")
            continue
        if tagged.stdout.strip() != expected:
            reasons.append(
                f"{repo.name}: tag {tag_name} resolves to "
                f"{tagged.stdout.strip()[:9]} but expected target was {expected[:9]}"
            )
    return reasons


def _push_tags(repos: list[Path], tag_name: str) -> list[str]:
    failures: list[str] = []
    for repo in repos:
        res = _run(["git", "push", PUSH_REMOTE, f"refs/tags/{tag_name}"], repo)
        if res.returncode != 0:
            err = res.stderr.strip() or "push failed"
            failures.append(f"{repo.name}: {err}")
            print(f"  {repo.name}: FAILED — {err}")
        else:
            print(f"  {repo.name}: pushed")
    return failures


def cmd_tag(args: argparse.Namespace) -> int:
    repos = _discover_repos()
    if not repos:
        print(f"No MAST_* repos found under {WORKSPACE_ROOT}")
        return EXIT_PREFLIGHT

    print(f"Workspace: {WORKSPACE_ROOT}")
    print(f"Discovered {len(repos)} MAST_* repos")
    print()

    if not args.allow_stale:
        print("Fetching all remotes for freshness check (use --allow-stale to skip)...")
    if args.from_ref:
        print(f"Tag target per repo: branch '{args.from_ref}' if present, else canonical mainline")
    states, fails = _preflight(
        repos,
        args.name,
        check_freshness=not args.allow_stale,
        prefer_ref=args.from_ref,
    )
    if fails:
        print("Preflight failed:")
        for f in fails:
            print(f"  - {f}")
        return EXIT_PREFLIGHT

    _print_plan(states, args.name)
    print()

    if not args.yes and not _confirm_by_typing(
        args.name,
        f"Type the tag name to confirm tagging {len(states)} repos with '{args.name}':",
    ):
        return EXIT_PREFLIGHT

    print()
    print("Applying tags...")
    tag_fails = _apply_tags(states, args.name, args.message)
    if tag_fails:
        print()
        print("Tagging had failures:")
        for f in tag_fails:
            print(f"  - {f}")
        return EXIT_PARTIAL_TAG

    expected_by_name = {s.name: s.target_sha for s in states}
    reasons = _evaluate_push_gate(WORKSPACE_ROOT, args.name, repos, expected_by_name)
    if reasons:
        print("Push gate FAILED — not offering push prompt:")
        for r in reasons:
            print(f"  - {r}")
        return EXIT_PUSH_GATE

    print(f"Push gate passed. Tags are local-only so far on {len(repos)} repos.")
    if not args.yes and not _confirm_by_typing(
        args.name,
        f"Push tag '{args.name}' to {PUSH_REMOTE} in all {len(repos)} repos? "
        f"Type the tag name to confirm (anything else aborts):",
    ):
        print(f"Push skipped. Tags remain local. Use `mast-release push {args.name}` to push later.")
        return EXIT_OK

    print()
    print(f"Pushing to {PUSH_REMOTE}...")
    push_fails = _push_tags(repos, args.name)
    if push_fails:
        print()
        print("Push had failures:")
        for f in push_fails:
            print(f"  - {f}")
        return EXIT_PARTIAL_PUSH

    print()
    print(f"Done. Tag '{args.name}' applied and pushed across {len(repos)} repos.")
    return EXIT_OK


def cmd_push(args: argparse.Namespace) -> int:
    repos = _discover_repos()
    if not repos:
        print(f"No MAST_* repos found under {WORKSPACE_ROOT}")
        return EXIT_PREFLIGHT

    missing: list[str] = []
    for repo in repos:
        res = _run(["git", "rev-parse", "--verify", f"refs/tags/{args.name}"], repo)
        if res.returncode != 0:
            missing.append(repo.name)
    if missing:
        print(f"Tag '{args.name}' missing locally in:")
        for m in missing:
            print(f"  - {m}")
        print("Run `mast-release tag` first.")
        return EXIT_PREFLIGHT

    reasons = _evaluate_push_gate(WORKSPACE_ROOT, args.name, repos)
    if reasons:
        print("Push gate FAILED:")
        for r in reasons:
            print(f"  - {r}")
        return EXIT_PUSH_GATE

    if not args.yes and not _confirm_by_typing(
        args.name,
        f"Push tag '{args.name}' to {PUSH_REMOTE} in all {len(repos)} repos? "
        f"Type the tag name to confirm:",
    ):
        return EXIT_OK

    print()
    print(f"Pushing to {PUSH_REMOTE}...")
    push_fails = _push_tags(repos, args.name)
    if push_fails:
        print()
        print("Push had failures:")
        for f in push_fails:
            print(f"  - {f}")
        return EXIT_PARTIAL_PUSH

    print()
    print(f"Done. Tag '{args.name}' pushed across {len(repos)} repos.")
    return EXIT_OK


def cmd_list(args: argparse.Namespace) -> int:
    repos = _discover_repos()
    pattern = args.pattern
    for repo in repos:
        cmd = ["git", "tag", "--list"]
        if pattern:
            cmd.append(pattern)
        res = _run(cmd, repo)
        tags = [t for t in res.stdout.splitlines() if t]
        print(f"{repo.name}: {', '.join(tags) if tags else '(none)'}")
    return EXIT_OK


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_tag = sub.add_parser("tag", help="apply an annotated tag at HEAD of every MAST_* repo")
    p_tag.add_argument("name", help="tag name, e.g. v2.0 or 2026-05-operational")
    p_tag.add_argument("message", help="annotation message (single argument; quote it)")
    p_tag.add_argument(
        "--yes",
        action="store_true",
        help="skip interactive confirmations (both pre-tag and pre-push)",
    )
    p_tag.add_argument(
        "--allow-stale",
        action="store_true",
        help=(
            "skip the freshness check (default: refuse to tag if any repo's "
            "tag target is behind its canonical upstream/origin mainline). "
            "Use only when you explicitly want to tag a stale ref."
        ),
    )
    p_tag.add_argument(
        "--from",
        dest="from_ref",
        default=None,
        metavar="BRANCH",
        help=(
            "tag this local branch's tip in each repo when the branch exists; "
            "otherwise fall back to that repo's canonical mainline tip "
            "(upstream/master, upstream/main, origin/main, or origin/master). "
            "Use when your release work lives on a shared branch like "
            "'eli/build-report' that not every repo has. Without --from, "
            "the tagger uses current HEAD in each repo."
        ),
    )
    p_tag.set_defaults(func=cmd_tag)

    p_push = sub.add_parser("push", help="push an already-applied tag to origin in every repo")
    p_push.add_argument("name", help="tag name to push")
    p_push.add_argument("--yes", action="store_true", help="skip interactive confirmation")
    p_push.set_defaults(func=cmd_push)

    p_list = sub.add_parser("list", help="list tags across all repos")
    p_list.add_argument("pattern", nargs="?", default=None, help="optional glob pattern")
    p_list.set_defaults(func=cmd_list)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
